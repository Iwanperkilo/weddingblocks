{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "weddingblocks/couple-title",
    "title": "WB Nama Cover",
    "category": "weddingblocks",
    "icon": "heading",
    "description": "Menampilkan nama panggilan kedua mempelai untuk judul cover.",
    "textdomain": "weddingblocks",
    "attributes": {
        "groomName": {
            "type": "string"
        },
        "groomNickname": {
            "type": "string"
        },
        "brideName": {
            "type": "string"
        },
        "brideNickname": {
            "type": "string"
        },
        "textColor": {
            "type": "string",
            "default": "#ffffff"
        },
        "textTransform": {
            "type": "string",
            "default": "none"
        },
        "separator": {
            "type": "string",
            "default": "&"
        },
        "textAlign": {
            "type": "string",
            "default": "center"
        },
        "textShadow": {
            "type": "boolean",
            "default": false
        },
        "animationStyle": {
            "type": "string",
            "default": "fadeIn"
        },
        "animationDuration": {
            "type": "number",
            "default": 800
        },
        "animationDelay": {
            "type": "number",
            "default": 0
        },
        "style": {
            "type": "object"
        }
    },
    "supports": {
        "align": [
            "wide",
            "full"
        ],
        "spacing": {
            "margin": true,
            "padding": true
        },
        "color": {
            "text": false,
            "background": false
        }
    },
    "editorScript": "file:./index.js",
    "render": "file:./render.php",
  "style": "weddingblocks-frontend-style",
  "script": "weddingblocks-frontend-script"
}
