{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "weddingblocks/countdown",
    "title": "WB Countdown",
    "category": "weddingblocks",
    "icon": "clock",
    "description": "Menampilkan waktu hitung mundur menuju hari pernikahan.",
    "textdomain": "weddingblocks",
    "attributes": {
        "targetDate": {
            "type": "string",
            "source": "meta",
            "meta": "weddingblocks_wedding_date"
        },
        "textColor": {
            "type": "string",
            "default": "#b5a46d"
        },
        "labelColor": {
            "type": "string",
            "default": "#888888"
        },
        "boxBackgroundColor": {
            "type": "string",
            "default": "#ffffff"
        },
        "borderColor": {
            "type": "string",
            "default": "#b5a46d"
        }
    },
    "editorScript": "file:./index.js",
    "render": "file:./render.php",
    "style": "weddingblocks-frontend-style",
    "script": "weddingblocks-frontend-script"
}
