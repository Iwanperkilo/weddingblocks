{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "weddingblocks/couple-info",
  "title": "WB Profil Mempelai",
  "category": "weddingblocks",
  "icon": "align-center",
  "description": "Menampilkan profil lengkap kedua mempelai (foto, nama, orang tua) secara berdampingan.",
  "textdomain": "weddingblocks",
  "attributes": {
    "groomName": {
      "type": "string"
    },
    "groomParents": {
      "type": "string"
    },
    "groomPhoto": {
      "type": "string"
    },
    "brideName": {
      "type": "string"
    },
    "brideParents": {
      "type": "string"
    },
    "bridePhoto": {
      "type": "string"
    },
    "swapCouple": {
      "type": "boolean",
      "default": false
    },
    "showParentsLabel": {
      "type": "boolean",
      "default": true
    },
    "parentsLabelGroom": {
      "type": "string",
      "default": "Putra dari"
    },
    "parentsLabelBride": {
      "type": "string",
      "default": "Putri dari"
    },
    "parentsLabelFontSize": {
      "type": "number",
      "default": 15
    },
    "parentsLabelFontFamily": {
      "type": "string",
      "default": "playfair"
    },
    "parentsLabelTextColor": {
      "type": "string",
      "default": "#333333"
    },
    "nameFontSize": {
      "type": "number",
      "default": 20
    },
    "nameTextColor": {
      "type": "string",
      "default": "#2c2c2c"
    },
    "avatarBorderColor": {
      "type": "string",
      "default": "#b5a46d"
    },
    "avatarBorderWidth": {
      "type": "number",
      "default": 4
    },
    "layout": {
      "type": "string",
      "default": "horizontal"
    },
    "animationStyle": {
      "type": "string",
      "default": "fadeUp"
    },
    "animationDuration": {
      "type": "number",
      "default": 600
    },
    "animationDelay": {
      "type": "number",
      "default": 0
    }
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php",
  "style": "weddingblocks-frontend-style",
  "script": "weddingblocks-frontend-script"
}
