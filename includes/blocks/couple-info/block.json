{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "weddingblocks/couple-info",
    "title": "WB Profil Mempelai",
    "category": "weddingblocks",
    "icon": "align-center",
    "description": "Menampilkan profil lengkap kedua mempelai (foto, nama, orang tua) secara berdampingan.",
    "textdomain": "weddingblocks",
    "attributes": {
        "groomName": {
            "type": "string",
            "source": "meta",
            "meta": "weddingblocks_groom_name"
        },
        "groomParents": {
            "type": "string",
            "source": "meta",
            "meta": "weddingblocks_groom_parents"
        },
        "groomPhoto": {
            "type": "string",
            "source": "meta",
            "meta": "weddingblocks_groom_photo"
        },
        "brideName": {
            "type": "string",
            "source": "meta",
            "meta": "weddingblocks_bride_name"
        },
        "brideParents": {
            "type": "string",
            "source": "meta",
            "meta": "weddingblocks_bride_parents"
        },
        "bridePhoto": {
            "type": "string",
            "source": "meta",
            "meta": "weddingblocks_bride_photo"
        }
    },
    "editorScript": "file:./index.js",
    "render": "file:./render.php",
    "style": "weddingblocks-frontend-style"
}
