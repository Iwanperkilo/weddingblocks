{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "weddingblocks/guest-name",
    "title": "WB Nama Tamu",
    "category": "weddingblocks",
    "icon": "admin-users",
    "description": "Menampilkan nama tamu undangan secara dinamis berdasarkan parameter URL.",
    "textdomain": "weddingblocks",
    "attributes": {
        "prefix": {
            "type": "string",
            "default": "Kepada Yth. Bapak/Ibu/Saudara/i:"
        },
        "fallback": {
            "type": "string",
            "default": "Tamu Undangan"
        },
        "textColor": {
            "type": "string",
            "default": "#333333"
        },
        "backgroundColor": {
            "type": "string",
            "default": "transparent"
        },
        "showPrefix": {
            "type": "boolean",
            "default": true
        },
        "textAlign": {
            "type": "string",
            "default": "center"
        },
        "fontSize": {
            "type": "string",
            "default": "medium"
        },
        "animationStyle": {
            "type": "string",
            "default": "fadeIn"
        },
        "animationDuration": {
            "type": "number",
            "default": 600
        },
        "animationDelay": {
            "type": "number",
            "default": 0
        }
    },
    "editorScript": "file:./index.js",
    "render": "file:./render.php",
    "style": "weddingblocks-frontend-style",
    "script": "weddingblocks-frontend-script"
}
